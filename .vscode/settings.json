{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.next/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.next": true
    }
}
