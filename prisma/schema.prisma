// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UploadType {
  BILLBOARD
  PRODUCT
}

enum BillboardStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
  REFUND
}

enum PromotionType {
  PERCENT
  FIXED
}

enum PromotionMode {
  COUPON
  CATEGORY_CAMPAIGN
}

enum AutoReplyType {
  NEGATIVE
  POSITIVE
  NORMAL
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("customer")

  sessions      Session[]
  accounts      Account[]
  stores        Store[]
  reviews       Review[]
  orders        Order[]

  stripeCustomer StripeCustomer?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Upload {
  id          String   @id @default(uuid())
  publicId    String   @unique
  url         String   @unique
  refType     UploadType
  mimetype    String?
  size        Int?
  isLinked    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([mimetype])
  @@index([isLinked, createdAt])
  @@index([refType])
}

model Store {
  id          String @id @default(uuid())
  name        String
  slug        String @unique
  thumbnail   String? 
  description String? @db.Text
  isFeatured  Boolean @default(false)
  userId      String

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  billboards  Billboard[] @relation("StoreToBillboard")
  categories  Category[]  @relation("StoreToCategory")
  sizes       Size[]      @relation("StoreToSize")
  colors      Color[]     @relation("StoreToColor")
  products    Product[]   @relation("StoreToProduct")
  orders      Order[]     @relation("StoreToOrder")
  promotions  Promotion[] @relation("StoreToPromotion")
  coupons     Coupon[]    @relation("StoreToCoupon")
  reviews     Review[]    @relation("StoreToReview")
  autoReplies AutoReply[] @relation("StoreToAutoReply")   
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Billboard {
  id         String @id @default(uuid())
  storeId    String
  label      String
  imageUrl   String
  isGlobal   Boolean @default(false)
  isActive   Boolean @default(false)

  store      Store @relation("StoreToBillboard", fields: [storeId], references: [id])
  categories Category[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId, isGlobal, isActive])
}

model Category {
  id          String @id @default(uuid())
  storeId     String
  billboardId String
  name        String

  sizes       Size[]      @relation("CategoryToSize")
  colors      Color[]     @relation("CategoryToColor")
  products    Product[]   @relation("CategoryToProduct")
  promotions  Promotion[] @relation("CategoryToPromotion")

  store       Store @relation("StoreToCategory", fields: [storeId], references: [id])
  billboard   Billboard @relation(fields: [billboardId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
  @@index([billboardId])
}

model Size {
  id          String @id @default(uuid())
  storeId     String
  categoryId  String
  name        String
  value       String @db.VarChar(10)

  products    Product[]

  store       Store @relation("StoreToSize", fields: [storeId], references: [id])
  category    Category @relation("CategoryToSize", fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, categoryId])
  @@unique([storeId, categoryId, value])
}

model Color {
  id          String @id @default(uuid())
  storeId     String
  categoryId  String
  name        String
  value       String @db.VarChar(10)

  products    Product[]

  store       Store @relation("StoreToColor", fields: [storeId], references: [id])
  category    Category @relation("CategoryToColor", fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, categoryId])
  @@unique([storeId, categoryId, value])
}

model Product {
  id          String @id @default(uuid())
  storeId     String
  categoryId  String
  sizeId      String
  colorId     String
  name        String
  sku         String @unique @db.VarChar(50)
  description String? @db.Text
  price       Decimal
  status      ProductStatus
  inStock     Boolean @default(false)
  isFeatured  Boolean @default(false)

  images      ProductImage[]
  orderItems  OrderItem[]
  reviews     Review[]

  store       Store @relation("StoreToProduct", fields: [storeId], references: [id])
  category    Category @relation("CategoryToProduct", fields: [categoryId], references: [id])
  size        Size @relation(fields: [sizeId], references: [id])
  color       Color @relation(fields: [colorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, categoryId, status])
  @@index([storeId, isFeatured, status])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Order {
  id            String @id @default(uuid())
  storeId       String
  couponId      String?
  userId        String
  status        OrderStatus
  phone         String @default("")
  address       String @default("")

  country       String?
  email         String?
  name          String?

  transactionId String? @unique
  receiptUrl    String?

  currency      String  @default("usd")
  amountPaid    Decimal?

  orderItems    OrderItem[]

  coupon        Coupon? @relation(fields: [couponId], references: [id])
  store         Store @relation("StoreToOrder", fields: [storeId], references: [id])
  user          User @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeId, status])
  @@index([couponId, userId])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String

  order     Order @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Promotion {
  id         String @id @default(uuid())
  name       String
  storeId    String
  type       PromotionType
  mode       PromotionMode
  value      Float
  startAt    DateTime
  endAt      DateTime
  isActive   Boolean @default(false)

  minOrderValue    Float  @default(0)
  maxDiscountValue Float?

  coupons    Coupon[]
  categories Category[] @relation("CategoryToPromotion")

  store      Store @relation("StoreToPromotion", fields: [storeId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId, isActive, startAt, endAt])
  @@index([storeId, mode])
}

model Coupon {
  id           String @id @default(uuid())
  storeId      String
  promotionId  String
  code         String @unique

  usageLimit   Int? @default(1)
  usedCount    Int  @default(0)
  perUserLimit Int? @default(1)

  orders       Order[]

  promotion    Promotion @relation(fields: [promotionId], references: [id])
  store        Store     @relation("StoreToCoupon", fields: [storeId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeId, code])
  @@index([promotionId])
}

model Review {
  id          String @id @default(uuid())
  storeId     String
  userId      String
  productId   String
  autoReplyId String?
  rating      Int     @db.SmallInt @default(0)
  feedback    String? @db.Text

  store       Store     @relation("StoreToReview", fields: [storeId], references: [id], onDelete: Cascade)
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  autoReply   AutoReply? @relation(fields: [autoReplyId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, productId])
  @@index([storeId, rating])
  @@unique([storeId, userId, productId])
}

model AutoReply {
  id        String @id @default(uuid())
  storeId   String
  content   String @db.Text
  type      AutoReplyType @default(NORMAL)
  isActive  Boolean @default(false)

  reviews   Review[]

  store       Store     @relation("StoreToAutoReply", fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive, type])
}

model StripeCustomer {
  id               String @id @default(uuid())
  userId           String @unique
  stripeCustomerId String @unique

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
